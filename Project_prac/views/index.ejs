<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task App</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen flex items-start justify-center pt-10">

    <div class="w-full max-w-3xl px-4">
        
        <!-- Input Box -->
        <div class="bg-gray-800 p-5 rounded-xl shadow-lg space-y-4">
          <% if(files.length > 0){ %>
           <% files.forEach(function(val){ %>
              <% }) %>
                <% } else { %>
                <h3>No taks yet</h3>
            <% } %>
            <input 
                type="text" 
                placeholder="Title goes here..." 
                class="w-full bg-gray-700 text-white px-4 py-3 rounded-lg outline-none focus:ring-2 focus:ring-blue-500"
            >

            <textarea 
                placeholder="Write your task details here..." 
                rows="4"
                class="w-full bg-gray-700 text-white px-4 py-3 rounded-lg outline-none focus:ring-2 focus:ring-blue-500"
            ></textarea>

            <button 
                class="bg-blue-600 hover:bg-blue-700 px-5 py-2 rounded-lg font-semibold transition"
            >
                Create Task
            </button>
        </div>

        <!-- Task List -->
        <div class="mt-8 text-gray-400">
            no tasks yet...
        </div>

    </div>

</body>
</html>